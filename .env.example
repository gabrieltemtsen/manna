# ─── Gemini (the agent brain) ────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
# Without a key, Manna falls back to a transparent heuristic planner, so the
# app still works for demos — but the AI reasoning is the whole point.
GEMINI_API_KEY=
# Optional override; defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-3.5-flash

# ─── Upstash Redis (impact garden persistence) ───────────────────────────────
# Optional. Without these, rounds live in memory (great for local dev, resets
# on serverless cold starts). Create a free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public URL where this miniapp is deployed (used for metadata only).
NEXT_PUBLIC_APP_URL=https://manna.example.com
